# Root gitignore to ignore dependency and build folders recursive
node_modules/
**/node_modules/

# Production builds
dist/
**/dist/
build/
**/build/

# Environment files and credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
server/.env

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# System files
.DS_Store
Thumbs.db

# IDE and Editor files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.agents/
.antigravityignore

